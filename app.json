{
  "expo": {
    "name": "NaBajk",
    "slug": "nabajk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nabajk",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nabajk.app",
      "buildNumber": "8",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "NaBajk uses your photo library to save and share ride images.",
        "FacebookAppID": "820735547692883",
        "FacebookDisplayName": "NaBajk",
        "LSApplicationQueriesSchemes": [
          "instagram",
          "instagram-stories",
          "fb",
          "facebook-stories"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "nabajk"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0F14"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nabajk.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "@maplibre/maplibre-react-native",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.968402921869-6g035oclj9ipjno4i77aqcoamqdrg1am"
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00BC7C",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "NaBajk uses your location to record cycling routes in the background.",
          "locationWhenInUsePermission": "NaBajk uses your location to record cycling routes.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/df3fd1bb-6e93-4a90-ac6c-9f7a99d08250"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df3fd1bb-6e93-4a90-ac6c-9f7a99d08250"
      }
    }
  }
}
